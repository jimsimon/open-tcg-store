{
  "name": "@open-tcgs/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx --conditions=development src/server.ts",
    "start": "NODE_ENV=production node --import tsx/esm src/server.ts",
    "build": "tsc && vite build",
    "db:update-better-auth-schema": "npx @better-auth/cli generate -y --output ./src/db/otcgs/auth-schema.ts",
    "db:generate": "drizzle-kit generate --config ./src/db/otcgs/drizzle.config.ts",
    "db:check": "drizzle-kit check --config ./src/db/otcgs/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ./src/db/otcgs/drizzle.config.ts",
    "db:push:main": "drizzle-kit push --config ./src/db/otcgs/drizzle.config.ts",
    "db:push:tcg-data": "drizzle-kit push --config ./src/db/tcg-data/drizzle.config.ts",
    "db:generate:tcg-data": "drizzle-kit generate --config ./src/db/tcg-data/drizzle.config.ts",
    "db:check:tcg-data": "drizzle-kit check --config ./src/db/tcg-data/drizzle.config.ts",
    "db:migrate:tcg-data": "drizzle-kit migrate --config ./src/db/tcg-data/drizzle.config.ts"
  },
  "dependencies": {
    "@open-tcgs/shared": "workspace:*"
  },
  "devDependencies": {}
}
