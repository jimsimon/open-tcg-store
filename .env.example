BETTER_AUTH_SECRET=replace-with-a-random-32-char-secret
BETTER_AUTH_URL=http://localhost

# Encryption key for sensitive settings (32 bytes hex)
ENCRYPTION_KEY=replace-with-64-hex-chars-representing-32-bytes

# Public app URL (used for CORS, OAuth redirect URIs, etc.)
APP_URL=http://localhost

# Internal API URL for direct server-to-server calls (bypasses nginx)
API_INTERNAL_URL=http://localhost:5174

# Google Drive OAuth (for backup/restore)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dropbox OAuth (for backup/restore)
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=

# OneDrive/Microsoft OAuth (for backup/restore)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
